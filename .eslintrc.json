{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:import/recommended",
    "prettier"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "indent": ["error", 2],
    "semi": ["error", "always"],
    "quotes": ["error", "double"],
    "no-unused-vars": ["warn"],
    "no-undef": ["error"]
  },
  "globals": {
    "QRCode": "writable",
    "jsQR": "writable",
    "MessageChannel": "writable",
    "globalThis": "writable",
    "crypto": "writable",
    "TextEncoder": "writable",
    "Blob": "writable"
  },
  "overrides": [
    {
      "files": ["js/qr.js", "js/share.js"],
      "rules": {
        "no-undef": "off"
      }
    },
    {
      "files": ["js/service-worker-manager.js"],
      "rules": {
        "no-undef": ["error", { "typeof": true }]
      }
    },
    {
      "files": ["js/data/IndexedDBManager.js"],
      "rules": {
        "no-undef": "off"
      }
    }
  ]
}
}
