# Graphify / Ollama Configuration
# Copy this file to .env and fill in your actual values

# Ollama API key (if required by your setup)
OLLAMA_API_KEY=your_api_key_here

# Ollama server endpoint
OLLAMA_ENDPOINT=http://localhost:11434/v1

# Model to use for semantic extraction
OLLAMA_MODEL=llama3.2

# Max concurrent extraction workers (adjust based on your hardware)
GRAPHIFY_MAX_CONCURRENCY=4

# Token budget per extraction chunk
GRAPHIFY_TOKEN_BUDGET=32000
