  },
  "lint-staged": {
    "*.js": "eslint --fix"
  },
  "dependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.58.2",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "^2.32.0",
    "express": "^5.2.1",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.0",
    "prettier": "^3.8.1",
    "qrcode": "^1.5.4",
    "vitest": "^4.0.18"
  }
