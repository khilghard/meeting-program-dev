{
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "analyze:unused": "knip --config knip.jsonc --no-progress --no-exit-code",
    "analyze:architecture": "depcruise --config .dependency-cruiser.cjs js src service-worker.js server.cjs scripts",
    "analyze:security": "bash scripts/precommit-semgrep.sh",
    "precommit:quality": "npm run analyze:unused && npm run analyze:architecture && npm run analyze:security",
    "husky": "husky install",
    "vendor:sync": "node scripts/sync-vendor-libs.mjs",
    "vendor:update": "npm update dexie qrcode jsqr uuid && npm run vendor:sync",
    "dev": "node server.cjs",
    "dev:test": "HOST=0.0.0.0 PORT=8000 node server.cjs",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": "eslint --fix"
  },
  "dependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.58.2",
    "@sonar/scan": "^4.3.4",
    "context-mode": "^1.0.135",
    "dexie": "^4.3.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "^2.32.0",
    "express": "^5.2.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.0",
    "opencode-ai": "^1.2.20",
    "prettier": "^3.8.1",
    "qrcode": "^1.5.4",
    "uuid": "^13.0.0",
    "vitest": "^4.0.18"
  },
  "devDependencies": {
    "@rigour-labs/cli": "^2.22.0",
    "@rigour-labs/core": "^2.22.0",
    "@rigour-labs/mcp": "^2.22.0",
    "@vitest/coverage-v8": "^4.0.18",
    "dependency-cruiser": "^18.1.0",
    "esbuild": "^0.28.0",
    "fake-indexeddb": "^6.2.5",
    "jsqr": "^1.4.0",
    "knip": "^6.27.0"
  }
}
