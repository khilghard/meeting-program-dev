{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "allow",
    "write": "allow",
    "read": "allow",
    "bash": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "skill": {
      "*": "allow",
      "internal-*": "deny",
      "experimental-*": "ask"
    },
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow",
    "todowrite": "allow",
    "todoread": "allow"
  },
  "agent": {
    "default": {
      "tools": {
        "skill": true
      }
    }
  }
}
